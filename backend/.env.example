# Copie este arquivo para ".env" e preencha os valores reais.
# O ".env" nunca deve ser commitado (já está no .gitignore).

# Postgres com a extensão pgvector habilitada.
DATABASE_URL="postgresql://postgres:123@localhost:5432/continentalmotors?schema=public"

# Chave de API do Gemini (Google AI Studio). Usada apenas no backend —
# nunca é exposta ao front-end.
GEMINI_API_KEY="sua_chave_do_gemini_aqui"

# Porta HTTP do backend (opcional, default 3333).
PORT=3333

# Origem permitida pelo CORS (opcional, default http://localhost:3000).
# Configure com a URL real do front-end em produção.
# FRONTEND_URL="http://localhost:3000"
